# ──────────────────────────────────────────────
# GazarZar Backend - Environment Configuration
# ──────────────────────────────────────────────

# Database
DATABASE_URL=sqlite:///./gazarzar.db

# Security
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
APP_NAME=GazarZar
APP_VERSION=1.0.0
DEBUG=True

# File Upload
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=10

# QPay (Real values from QPay dashboard)
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=your_qpay_username
QPAY_PASSWORD=your_qpay_password
QPAY_INVOICE_CODE=your_invoice_code

# SMS Gateway (e.g. sms.mn)
SMS_API_URL=https://api.sms.mn/v1/send
SMS_API_KEY=your_sms_api_key
SMS_SENDER=GazarZar

# Cloudflare R2 - persistent image storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://pub-your-hash.r2.dev
